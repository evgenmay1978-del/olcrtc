{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(go build ./...)",
      "Bash(go test:*)",
      "Bash(go vet ./...)",
      "Bash(go mod tidy)",
      "Bash(gofmt:*)",
      "Bash(mage:*)",
      "Bash(golangci-lint run:*)",
      "Bash(govulncheck ./...)"
    ],
    "deny": [
      "Read(./crypto.key)",
      "Read(./**/*.key)",
      "Read(./.env)"
    ]
  }
}
